# ==== Instagram credentials ====
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Optional: 2FA seed (TOTP). Leave empty if you don't use 2FA or prefer
# being prompted for the code at login time.
IG_TOTP_SEED=

# ==== Traitor detection ====
# A "traitor" = someone you follow, who doesn't follow you back,
# AND who has fewer followers than this threshold (i.e. not a big account
# you'd follow anyway for content).
TRAITOR_FOLLOWER_THRESHOLD=10000

# Also flag as traitor if the account is private? (true/false)
TRAITOR_INCLUDE_PRIVATE=true

# Also flag verified accounts? (usually false - you want to keep them)
TRAITOR_INCLUDE_VERIFIED=false

# ==== Safety: accounts you NEVER want to unfollow ====
# Comma-separated list of usernames (without @).
WHITELIST=

# ==== Rate limiting (anti-ban) ====
# Random delay between two unfollow actions, in seconds.
UNFOLLOW_DELAY_MIN=35
UNFOLLOW_DELAY_MAX=90

# Max unfollow actions per run (0 = no limit, but NOT recommended).
UNFOLLOW_MAX_PER_RUN=40

# Long pause every N actions (to mimic human behaviour).
UNFOLLOW_PAUSE_EVERY=15
UNFOLLOW_LONG_PAUSE_MIN=300
UNFOLLOW_LONG_PAUSE_MAX=600

# ==== Storage ====
SESSION_FILE=data/session.json
CACHE_DIR=data
